# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is git-ignored — never commit real credentials.

# Backend API URL (can also be set via ASK_URL env var)
ASK_URL = "https://tyo007o8qe.execute-api.us-east-1.amazonaws.com/prod/ask"

# ---------------------------------------------------------------------------
# Synapse OAuth client
# Register at: https://www.synapse.org/#!OAuthClientManagement:
# Set redirect URI to: http://<your-host>:8501  (the bare app URL, no path)
# ---------------------------------------------------------------------------

[synapse_oauth]
client_id     = ""
client_secret = ""
redirect_uri  = "http://192.168.1.12:8501"
